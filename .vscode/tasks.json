{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo check",
      "type": "shell",
      "command": "cargo",
      "args": [
        "check"
      ],
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo clippy",
      "type": "shell",
      "command": "cargo",
      "args": [
        "clippy",
        "--all-targets",
        "--all-features"
      ],
      "group": "test",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo test",
      "type": "shell",
      "command": "cargo",
      "args": [
        "test"
      ],
      "group": "test",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo run",
      "type": "shell",
      "command": "cargo",
      "args": [
        "run"
      ],
      "problemMatcher": [
        "$rustc"
      ]
    }
  ]
}
